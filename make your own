    const size = 10 + Math.random()*28;
    const duration = 12 + Math.random()*20;
    const delay = Math.random()*18;
    const opacity = 0.04 + Math.random()*0.12;
    const blur = Math.random()*3;
    const rot = (Math.random()-0.5)*60;
    h.style.cssText = `--s:${size}px;--d:${duration}s;--delay:${delay}s;--x:${Math.random()*100}%;--op:${opacity};--blur:${blur}px;--rot:${rot}deg;`;
    container.appendChild(h);
  }
})();

// ─── DB ───
let db;
function openDB(){
  return new Promise((res,rej)=>{
    const req = indexedDB.open('MemoireDB',2);
    req.onupgradeneeded = e=>{
      const d=e.target.result;
      if(!d.objectStoreNames.contains('vlogs')){
        const s=d.createObjectStore('vlogs',{keyPath:'id',autoIncrement:true});
        s.createIndex('owner','owner',{unique:false});
        s.createIndex('shareCode','shareCode',{unique:false});
      }
    };
    req.onsuccess = e=>{ db=e.target.result; res(db); };
    req.onerror = ()=>rej(req.error);
  });
}

function saveVlog(vlog){
  return new Promise((res,rej)=>{
    const tx=db.transaction('vlogs','readwrite');
    const req=tx.objectStore('vlogs').add(vlog);
    req.onsuccess=()=>res(req.result);
    req.onerror=()=>rej(req.error);
  });
}

function getVlogs(owner){
  return new Promise((res,rej)=>{
    const tx=db.transaction('vlogs','readonly');
    const idx=tx.objectStore('vlogs').index('owner');
    const req=idx.getAll(owner);
    req.onsuccess=()=>res(req.result);
    req.onerror=()=>rej(req.error);
  });
}

function getVlogByCode(code){
  return new Promise((res,rej)=>{
    const tx=db.transaction('vlogs','readonly');
    const idx=tx.objectStore('vlogs').index('shareCode');
    const req=idx.get(code);
    req.onsuccess=()=>res(req.result||null);
    req.onerror=()=>rej(req.error);
  });
}

function deleteVlog(id){
  return new Promise((res,rej)=>{
    const tx=db.transaction('vlogs','readwrite');
    tx.objectStore('vlogs').delete(id);
    tx.oncomplete=res;
    tx.onerror=()=>rej(tx.error);
  });
}

// ─── AUTH (Google GSI mock + simulated token) ───
let currentUser = null;

function handleGoogleSignIn(){
  // Use Google Identity Services if loaded, else simulate
  if(window.google && google.accounts){
    google.accounts.id.initialize({
      client_id: '<!-- REPLACE_WITH_YOUR_GOOGLE_CLIENT_ID -->',
      callback: onGoogleCredential
    });
    google.accounts.id.prompt(n=>{
      if(n.isNotDisplayed() || n.isSkippedMoment()){
        // Fallback demo mode
        simulateSignIn();
      }
    });
  } else {
    simulateSignIn();
  }
}

function simulateSignIn(){
  // Demo: simulate a signed-in user stored in sessionStorage
  const stored = sessionStorage.getItem('memoireUser');
  if(stored){
    currentUser = JSON.parse(stored);
  } else {
    const demoEmail = prompt('Enter your email to sign in (demo mode):', 'you@example.com') || 'guest@memoire.app';
    const name = demoEmail.split('@')[0].replace(/[._]/g,' ').replace(/\b\w/g,c=>c.toUpperCase());
    currentUser = { email: demoEmail, name, picture: '' };
    sessionStorage.setItem('memoireUser', JSON.stringify(currentUser));
  }
  loadApp();
}

function onGoogleCredential(resp){
  // Decode JWT payload
  try {
    const payload = JSON.parse(atob(resp.credential.split('.')[1]));
    currentUser = { email: payload.email, name: payload.name, picture: payload.picture };
    sessionStorage.setItem('memoireUser', JSON.stringify(currentUser));
    loadApp();
  } catch(e){ simulateSignIn(); }
}

async function loadApp(){
  await openDB();
  document.getElementById('landing').style.display='none';
  document.getElementById('app').classList.add('visible');
  document.getElementById('userName').textContent = currentUser.name;
  if(currentUser.picture){
    document.getElementById('userAvatar').src = currentUser.picture;
  }
  renderGallery();
}

function signOut(){
  sessionStorage.removeItem('memoireUser');
  currentUser = null;
  document.getElementById('app').classList.remove('visible');
  document.getElementById('landing').style.display='flex';
  stopCamera();
}

// Check session on load
window.addEventListener('load', async ()=>{
  await openDB();
  const stored = sessionStorage.getItem('memoireUser');
  if(stored){
    currentUser = JSON.parse(stored);
    loadApp();
  }
});

// ─── TABS ───
function switchTab(name){
  document.querySelectorAll('.tab').forEach((t,i)=>{
    const names=['record','gallery','shared'];
    t.classList.toggle('active', names[i]===name);
  });
  document.querySelectorAll('[id^="tab-"]').forEach(el=>{
    el.classList.remove('active');
  });
  document.getElementById('tab-'+name).classList.add('active');
  if(name==='gallery') renderGallery();
}

// ─── CAMERA & RECORDING ───
let stream=null, recorder=null, chunks=[], timerInterval=null, elapsed=0, selectedMood='';

async function startCamera(){
  try{
    stream = await navigator.mediaDevices.getUserMedia({video:true,audio:true});
    const vid = document.getElementById('previewVideo');
    vid.srcObject = stream;
    vid.style.display = 'block';
    document.getElementById('camPlaceholder').style.display='none';
    document.getElementById('startRecBtn').disabled=false;
    document.getElementById('startCamBtn').disabled=true;
    showToast('Camera ready ♥');
  } catch(e){
    showToast('Could not access camera. Please allow permissions.');
  }
}

function stopCamera(){
  if(stream){ stream.getTracks().forEach(t=>t.stop()); stream=null; }
  const vid=document.getElementById('previewVideo');
  vid.style.display='none'; vid.srcObject=null;
  document.getElementById('camPlaceholder').style.display='flex';
  document.getElementById('startRecBtn').disabled=true;
  document.getElementById('startCamBtn').disabled=false;
}

function startRecording(){
  if(!stream) return;
  chunks=[];
  recorder = new MediaRecorder(stream, {mimeType: getSupportedMime()});
  recorder.ondataavailable = e=>{ if(e.data.size>0) chunks.push(e.data); };
  recorder.onstop = finalizeRecording;
  recorder.start(1000);

  document.getElementById('recIndicator').classList.add('on');
  document.getElementById('recTimer').style.display='block';
  document.getElementById('startRecBtn').style.display='none';
  document.getElementById('stopRecBtn').style.display='block';
  document.getElementById('stopRecBtn').disabled=false;
  document.getElementById('startCamBtn').disabled=true;

  elapsed=0;
  updateTimer();
  timerInterval=setInterval(()=>{ elapsed++; updateTimer(); },1000);
}

function updateTimer(){
  const m=Math.floor(elapsed/60);
  const s=(elapsed%60).toString().padStart(2,'0');
  document.getElementById('recTimer').textContent=`${m}:${s}`;
}

function stopRecording(){
  if(recorder && recorder.state!=='inactive') recorder.stop();
  clearInterval(timerInterval);
  document.getElementById('recIndicator').classList.remove('on');
  document.getElementById('recTimer').style.display='none';
  document.getElementById('stopRecBtn').style.display='none';
  document.getElementById('startRecBtn').style.display='block';
}

async function finalizeRecording(){
  const mime = getSupportedMime();
  const blob = new Blob(chunks, {type: mime});

  const title = document.getElementById('vlogTitle').value.trim() || 'Untitled Memory';
  const note = document.getElementById('vlogNote').value.trim();

  document.getElementById('savingMsg').style.display='block';

  const arrayBuf = await blob.arrayBuffer();

  const shareCode = 'MEM-' + randomStr(4) + '-' + randomStr(4);

  await saveVlog({
    owner: currentUser.email,
    title,
    note,
    mood: selectedMood || '—',
    date: new Date().toISOString(),
    videoData: arrayBuf,
    videoMime: mime,
    shareCode,
    sharedWith: []
  });

  document.getElementById('savingMsg').style.display='none';
  document.getElementById('vlogTitle').value='';
  document.getElementById('vlogNote').value='';
  document.querySelectorAll('.mood-btn').forEach(b=>b.classList.remove('selected'));
  selectedMood='';

  stopCamera();
  showToast('Your memory has been saved ♥');
  switchTab('gallery');
}

function getSupportedMime(){
  const types=['video/webm;codecs=vp9','video/webm;codecs=vp8','video/webm','video/mp4'];
  for(const t of types){ if(MediaRecorder.isTypeSupported(t)) return t; }
  return 'video/webm';
}

function selectMood(btn, mood){
  document.querySelectorAll('.mood-btn').forEach(b=>b.classList.remove('selected'));
  btn.classList.add('selected');
  selectedMood=mood;
}

// ─── GALLERY ───
let currentFilter='all';

async function renderGallery(){
  if(!currentUser||!db) return;
  const vlogs = await getVlogs(currentUser.email);
  vlogs.sort((a,b)=>new Date(b.date)-new Date(a.date));

  const filtered = currentFilter==='all' ? vlogs : vlogs.filter(v=>v.mood===currentFilter);
  const grid = document.getElementById('vlogGrid');
  grid.innerHTML='';

  if(!filtered.length){
    grid.innerHTML=`<div class="empty-state"><div class="es-icon">♡</div><p>No memories yet. Begin your first vlog today.</p></div>`;
    return;
  }

  filtered.forEach(vlog=>{
    const blob = new Blob([vlog.videoData],{type:vlog.videoMime||'video/webm'});
    const url = URL.createObjectURL(blob);
    const dateStr = new Date(vlog.date).toLocaleDateString('en-US',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
    const shortDate = new Date(vlog.date).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});

    const card = document.createElement('div');
    card.className='vlog-card';
    card.innerHTML=`
      <div class="card-thumb" onclick="openModal(${vlog.id})">
        <video src="${url}" preload="metadata" muted></video>
        <div class="card-thumb-overlay"></div>
        <div class="card-play"><svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg></div>
        ${vlog.mood && vlog.mood!=='—' ? `<div class="card-mood-badge">${vlog.mood}</div>` : ''}
      </div>
      <div class="card-body">
        <div class="card-date">${shortDate}</div>
        <div class="card-title">${vlog.title}</div>
        ${vlog.note ? `<div class="card-note">${vlog.note}</div>` : ''}
      </div>
      <div class="card-actions">
        <button class="card-action-btn" onclick="openModal(${vlog.id})">▶ Play</button>
        <button class="card-action-btn" onclick="downloadVlog(${vlog.id})">⬇ Download</button>
        <button class="card-action-btn danger" onclick="deleteVlogEntry(${vlog.id})">🗑 Delete</button>
      </div>`;
    grid.appendChild(card);
  });
}

function filterMood(btn, mood){
  currentFilter=mood;
  document.querySelectorAll('.filter-chip').forEach(c=>c.classList.remove('active'));
  btn.classList.add('active');
  renderGallery();
}

// ─── MODAL ───
let currentModalId=null;

async function openModal(id){
  currentModalId=id;
  const vlogs = await getVlogs(currentUser.email);
  const vlog = vlogs.find(v=>v.id===id);
  if(!vlog) return;

  document.getElementById('modalTitle').textContent=vlog.title;
  document.getElementById('modalDate').textContent=new Date(vlog.date).toLocaleDateString('en-US',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
  document.getElementById('modalMood').textContent=vlog.mood||'—';
  document.getElementById('modalNote').textContent=vlog.note||'Nothing written.';
  document.getElementById('shareCodeDisplay').value=vlog.shareCode||'';

  const blob=new Blob([vlog.videoData],{type:vlog.videoMime||'video/webm'});
  const url=URL.createObjectURL(blob);
  const mv=document.getElementById('modalVideo');
  mv.src=url;

  // Only show share panel for owner
  document.getElementById('sharePanel').style.display='block';

  document.getElementById('videoModal').classList.add('open');
}

function closeModal(){
  document.getElementById('videoModal').classList.remove('open');
  const mv=document.getElementById('modalVideo');
  mv.pause(); mv.src='';
  currentModalId=null;
}

function copyShareCode(){
  const code=document.getElementById('shareCodeDisplay').value;
  navigator.clipboard.writeText(code).then(()=>showToast('Code copied! Share it with someone you trust ♥'));
}

function sendShareInvite(){
  const email=document.getElementById('shareEmail').value.trim();
  if(!email){ showToast('Please enter an email address'); return; }
  showToast(`Invite sent to ${email} ♥ (demo — no email sent in standalone mode)`);
  document.getElementById('shareEmail').value='';
}

// ─── SHARED ACCESS ───
async function viewShared(){
  const code=document.getElementById('accessCodeInput').value.trim().toUpperCase();
  if(!code){ showToast('Please enter an access code'); return; }
  const vlog=await getVlogByCode(code);
  if(!vlog){
    showToast('No memory found with that code. Please check and try again.');
    return;
  }
  // Show in shared grid
  const grid=document.getElementById('sharedVlogGrid');
  const blob=new Blob([vlog.videoData],{type:vlog.videoMime||'video/webm'});
  const url=URL.createObjectURL(blob);
  const shortDate=new Date(vlog.date).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
  grid.innerHTML=`
    <div class="vlog-card" style="max-width:380px;">
      <div class="card-thumb">
        <video src="${url}" controls style="width:100%;height:100%;object-fit:cover;display:block;"></video>
        <div class="card-thumb-overlay"></div>
        ${vlog.mood && vlog.mood!=='—'?`<div class="card-mood-badge">${vlog.mood}</div>`:''}
      </div>
      <div class="card-body">
        <div class="card-date">${shortDate} · Shared with you</div>
        <div class="card-title">${vlog.title}</div>
        ${vlog.note?`<div class="card-note">${vlog.note}</div>`:''}
      </div>
    </div>`;
  showToast('Memory opened ♥ Read-only access granted');
}

// ─── DOWNLOAD ───
async function downloadVlog(id){
  const vlogs=await getVlogs(currentUser.email);
  const vlog=vlogs.find(v=>v.id===id);
  if(!vlog) return;
  const blob=new Blob([vlog.videoData],{type:vlog.videoMime||'video/webm'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');
  a.href=url; a.download=`${vlog.title.replace(/\s+/g,'_')}.webm`;
  a.click();
  URL.revokeObjectURL(url);
  showToast('Downloading your memory…');
}

async function deleteVlogEntry(id){
  if(!confirm('Delete this memory? This cannot be undone.')) return;
  await deleteVlog(id);
  renderGallery();
  showToast('Memory removed.');
}

// ─── UTILS ───
function randomStr(len){
  const chars='ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
  return Array.from({length:len},()=>chars[Math.floor(Math.random()*chars.length)]).join('');
}

let toastTimeout;
function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg;
  t.classList.add('show');
  clearTimeout(toastTimeout);
  toastTimeout=setTimeout(()=>t.classList.remove('show'),3200);
}

// Close modal on overlay click
document.getElementById('videoModal').addEventListener('click',function(e){
  if(e.target===this) closeModal();
});
</script>
