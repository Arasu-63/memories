<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Mémoire — Your Daily Heart</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Sacramento&family=DM+Serif+Display:ital@0;1&family=Crimson+Pro:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet"/>
<script src="https://accounts.google.com/gsi/client" async defer></script>
<style>
  :root {
    --ink: #1a1008;
    --parchment: #f5ede0;
    --sepia: #8b5e3c;
    --amber: #c8872a;
    --blush: #d4847a;
    --rose: #9b4a54;
    --cream: #faf6ef;
    --dust: #e8d9c5;
    --shadow: rgba(26,16,8,0.35);
    --heart: #b83c52;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--ink);
    color: var(--parchment);
    font-family: 'Crimson Pro', Georgia, serif;
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
  }

  /* Film grain overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.4;
  }

  /* Floating hearts background */
  .hearts-bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }

  .heart-float {
    position: absolute;
    font-size: var(--s);
    opacity: 0;
    animation: floatUp var(--d) ease-in var(--delay) infinite;
    left: var(--x);
    bottom: -5%;
    color: var(--heart);
    filter: blur(var(--blur));
  }

  @keyframes floatUp {
    0% { opacity: 0; transform: translateY(0) rotate(var(--rot)); }
    15% { opacity: var(--op); }
    85% { opacity: var(--op); }
    100% { opacity: 0; transform: translateY(-110vh) rotate(calc(var(--rot) + 30deg)); }
  }

  /* Vignette */
  .vignette {
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 40%, rgba(10,5,2,0.75) 100%);
    pointer-events: none;
    z-index: 1;
  }

  /* Page wrapper */
  .page { position: relative; z-index: 2; min-height: 100vh; }

  /* ── LANDING / LOGIN ── */
  #landing {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    text-align: center;
    padding: 2rem;
  }

  .brand-tagline {
    font-family: 'Sacramento', cursive;
    font-size: clamp(1rem, 3vw, 1.4rem);
    color: var(--amber);
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
    opacity: 0;
    animation: fadeIn 1s ease 0.3s forwards;
  }

  .brand-name {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(4rem, 12vw, 8rem);
    line-height: 0.9;
    color: var(--parchment);
    text-shadow: 0 0 60px rgba(200,135,42,0.3);
    opacity: 0;
    animation: fadeIn 1.2s ease 0.6s forwards;
    letter-spacing: -0.02em;
  }

  .brand-name em {
    font-style: italic;
    color: var(--blush);
  }

  .brand-sub {
    font-family: 'Crimson Pro', serif;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--dust);
    font-style: italic;
    margin-top: 1rem;
    max-width: 480px;
    line-height: 1.7;
    opacity: 0;
    animation: fadeIn 1s ease 1s forwards;
  }

  .divider-hearts {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 2.5rem 0;
    opacity: 0;
    animation: fadeIn 1s ease 1.3s forwards;
  }
  .divider-hearts::before, .divider-hearts::after {
    content: '';
    height: 1px;
    width: 80px;
    background: linear-gradient(90deg, transparent, var(--sepia));
  }
  .divider-hearts::after { background: linear-gradient(90deg, var(--sepia), transparent); }
  .divider-hearts span { color: var(--heart); font-size: 0.9rem; }

  .google-btn {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    background: var(--parchment);
    color: var(--ink);
    border: none;
    padding: 0.9rem 2rem;
    border-radius: 4px;
    font-family: 'Crimson Pro', serif;
    font-size: 1.1rem;
    font-weight: 400;
    cursor: pointer;
    transition: all 0.3s ease;
    letter-spacing: 0.02em;
    box-shadow: 0 4px 20px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.8);
    opacity: 0;
    animation: fadeIn 1s ease 1.6s forwards;
  }
  .google-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(200,135,42,0.3), inset 0 1px 0 rgba(255,255,255,0.8); }
  .google-btn svg { width: 20px; height: 20px; }

  .privacy-note {
    margin-top: 1.5rem;
    font-size: 0.85rem;
    color: rgba(245,237,224,0.4);
    font-style: italic;
    opacity: 0;
    animation: fadeIn 1s ease 2s forwards;
  }

  @keyframes fadeIn { to { opacity: 1; } }

  /* ── APP SHELL ── */
  #app { display: none; flex-direction: column; min-height: 100vh; }
  #app.visible { display: flex; }

  .top-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2rem;
    border-bottom: 1px solid rgba(139,94,60,0.25);
    backdrop-filter: blur(6px);
    background: rgba(26,16,8,0.6);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .top-logo {
    font-family: 'DM Serif Display', serif;
    font-size: 1.6rem;
    color: var(--parchment);
  }
  .top-logo em { font-style: italic; color: var(--blush); }

  .user-area {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .user-avatar {
    width: 36px; height: 36px;
    border-radius: 50%;
    border: 2px solid var(--amber);
    object-fit: cover;
  }

  .user-name {
    font-family: 'Crimson Pro', serif;
    font-size: 0.95rem;
    color: var(--dust);
    font-style: italic;
  }

  .sign-out-btn {
    background: none;
    border: 1px solid rgba(139,94,60,0.4);
    color: var(--sepia);
    padding: 0.3rem 0.8rem;
    border-radius: 3px;
    font-family: 'Crimson Pro', serif;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .sign-out-btn:hover { border-color: var(--rose); color: var(--rose); }

  /* ── TABS ── */
  .tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid rgba(139,94,60,0.2);
    padding: 0 2rem;
    background: rgba(26,16,8,0.4);
  }
  .tab {
    font-family: 'Crimson Pro', serif;
    font-size: 1rem;
    color: rgba(245,237,224,0.45);
    padding: 0.8rem 1.5rem;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all 0.3s;
    letter-spacing: 0.04em;
  }
  .tab.active { color: var(--amber); border-bottom-color: var(--amber); }
  .tab:hover:not(.active) { color: var(--dust); }

  /* ── MAIN CONTENT ── */
  .main { flex: 1; padding: 2rem; max-width: 1100px; margin: 0 auto; width: 100%; }

  /* ── RECORD TAB ── */
  #tab-record { display: none; }
  #tab-record.active { display: block; }

  .record-header {
    text-align: center;
    margin-bottom: 2rem;
  }
  .record-header h2 {
    font-family: 'Sacramento', cursive;
    font-size: 3rem;
    color: var(--blush);
    line-height: 1;
  }
  .record-header p {
    color: var(--dust);
    font-style: italic;
    margin-top: 0.3rem;
    font-size: 1.05rem;
  }

  .record-stage {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 2rem;
    align-items: start;
  }

  @media(max-width: 768px) {
    .record-stage { grid-template-columns: 1fr; }
  }

  .video-frame {
    position: relative;
    background: #0d0804;
    border-radius: 4px;
    overflow: hidden;
    aspect-ratio: 16/9;
    border: 2px solid rgba(139,94,60,0.3);
    box-shadow: 0 0 0 1px rgba(200,135,42,0.1), 0 20px 60px rgba(0,0,0,0.6);
  }

  .video-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(200,135,42,0.05) 0%, transparent 50%, rgba(155,74,84,0.05) 100%);
    z-index: 1;
    pointer-events: none;
  }

  .video-frame video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .rec-indicator {
    position: absolute;
    top: 12px;
    left: 12px;
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(0,0,0,0.6);
    padding: 4px 10px;
    border-radius: 20px;
    z-index: 2;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .rec-indicator.on { opacity: 1; }
  .rec-dot {
    width: 8px; height: 8px;
    background: #e53e3e;
    border-radius: 50%;
    animation: blink 1s infinite;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.2} }
  .rec-text { font-size: 0.75rem; letter-spacing: 0.1em; color: #fff; }

  .rec-timer {
    position: absolute;
    bottom: 12px;
    right: 12px;
    font-family: 'Crimson Pro', serif;
    font-size: 1.1rem;
    color: rgba(255,255,255,0.8);
    background: rgba(0,0,0,0.5);
    padding: 2px 10px;
    border-radius: 20px;
    z-index: 2;
  }

  .cam-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    color: rgba(245,237,224,0.3);
    z-index: 0;
  }
  .cam-placeholder .ph-icon { font-size: 3rem; }
  .cam-placeholder p { font-style: italic; font-size: 1rem; }

  /* Controls panel */
  .controls-panel {
    background: rgba(26,16,8,0.7);
    border: 1px solid rgba(139,94,60,0.25);
    border-radius: 4px;
    padding: 1.5rem;
    backdrop-filter: blur(8px);
  }

  .panel-title {
    font-family: 'Sacramento', cursive;
    font-size: 1.8rem;
    color: var(--amber);
    margin-bottom: 1rem;
  }

  .form-group { margin-bottom: 1.2rem; }
  .form-label {
    display: block;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sepia);
    margin-bottom: 0.4rem;
  }
  .form-input, .form-textarea, .form-select {
    width: 100%;
    background: rgba(245,237,224,0.06);
    border: 1px solid rgba(139,94,60,0.3);
    color: var(--parchment);
    padding: 0.6rem 0.8rem;
    border-radius: 3px;
    font-family: 'Crimson Pro', serif;
    font-size: 1rem;
    transition: border-color 0.2s;
    resize: none;
  }
  .form-input:focus, .form-textarea:focus, .form-select:focus {
    outline: none;
    border-color: var(--amber);
  }
  .form-select option { background: #1a1008; }

  .mood-row {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .mood-btn {
    background: rgba(245,237,224,0.05);
    border: 1px solid rgba(139,94,60,0.25);
    color: var(--dust);
    padding: 0.3rem 0.7rem;
    border-radius: 20px;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'Crimson Pro', serif;
  }
  .mood-btn.selected { background: rgba(184,60,82,0.25); border-color: var(--rose); color: var(--blush); }

  .action-btns { display: flex; flex-direction: column; gap: 0.8rem; margin-top: 1.5rem; }

  .btn {
    padding: 0.75rem 1.5rem;
    border-radius: 3px;
    font-family: 'Crimson Pro', serif;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.25s;
    border: none;
    letter-spacing: 0.03em;
    text-align: center;
    font-weight: 400;
  }
  .btn-primary {
    background: linear-gradient(135deg, var(--rose), var(--heart));
    color: #fff;
    box-shadow: 0 4px 15px rgba(184,60,82,0.4);
  }
  .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(184,60,82,0.5); }
  .btn-secondary {
    background: transparent;
    color: var(--amber);
    border: 1px solid rgba(200,135,42,0.4);
  }
  .btn-secondary:hover { background: rgba(200,135,42,0.08); }
  .btn-danger {
    background: transparent;
    color: var(--sepia);
    border: 1px solid rgba(139,94,60,0.3);
  }
  .btn-danger:hover { border-color: var(--rose); color: var(--rose); }
  .btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none !important; }

  /* ── GALLERY TAB ── */
  #tab-gallery { display: none; }
  #tab-gallery.active { display: block; }

  .gallery-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .gallery-header h2 {
    font-family: 'Sacramento', cursive;
    font-size: 2.8rem;
    color: var(--blush);
  }

  .filter-row { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .filter-chip {
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    border: 1px solid rgba(139,94,60,0.3);
    color: var(--dust);
    font-family: 'Crimson Pro', serif;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s;
    background: none;
  }
  .filter-chip.active { background: rgba(200,135,42,0.15); border-color: var(--amber); color: var(--amber); }

  .vlog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .vlog-card {
    background: rgba(26,16,8,0.8);
    border: 1px solid rgba(139,94,60,0.2);
    border-radius: 4px;
    overflow: hidden;
    transition: all 0.3s ease;
    position: relative;
    cursor: pointer;
    animation: cardIn 0.4s ease forwards;
  }
  @keyframes cardIn { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:none; } }
  .vlog-card:hover { transform: translateY(-4px); border-color: rgba(200,135,42,0.4); box-shadow: 0 12px 40px rgba(0,0,0,0.5); }

  .card-thumb {
    position: relative;
    aspect-ratio: 16/9;
    background: #0d0804;
    overflow: hidden;
  }
  .card-thumb video {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .card-thumb-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 50%, rgba(10,5,2,0.85) 100%);
  }
  .card-play {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 44px; height: 44px;
    background: rgba(200,135,42,0.85);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .vlog-card:hover .card-play { opacity: 1; }
  .card-mood-badge {
    position: absolute;
    top: 8px; right: 8px;
    background: rgba(0,0,0,0.55);
    border-radius: 12px;
    padding: 2px 8px;
    font-size: 0.75rem;
    color: var(--dust);
    backdrop-filter: blur(4px);
  }

  .card-body { padding: 1rem; }
  .card-date {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: var(--sepia);
    text-transform: uppercase;
    margin-bottom: 0.3rem;
  }
  .card-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    color: var(--parchment);
    margin-bottom: 0.5rem;
    line-height: 1.35;
  }
  .card-note {
    font-size: 0.88rem;
    color: rgba(245,237,224,0.5);
    font-style: italic;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.7rem 1rem;
    border-top: 1px solid rgba(139,94,60,0.15);
  }
  .card-action-btn {
    background: none;
    border: none;
    color: rgba(245,237,224,0.35);
    cursor: pointer;
    font-size: 0.8rem;
    display: flex;
    align-items: center;
    gap: 4px;
    transition: color 0.2s;
    font-family: 'Crimson Pro', serif;
    padding: 2px 6px;
    border-radius: 3px;
  }
  .card-action-btn:hover { color: var(--amber); }
  .card-action-btn.danger:hover { color: var(--rose); }

  .empty-state {
    grid-column: 1/-1;
    text-align: center;
    padding: 5rem 2rem;
    color: rgba(245,237,224,0.3);
  }
  .empty-state .es-icon { font-size: 4rem; margin-bottom: 1rem; }
  .empty-state p { font-style: italic; font-size: 1.1rem; }

  /* ── MODAL (video player) ── */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(10,5,2,0.92);
    z-index: 500;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    backdrop-filter: blur(8px);
  }
  .modal-overlay.open { display: flex; }
  .modal-box {
    background: #140d06;
    border: 1px solid rgba(139,94,60,0.35);
    border-radius: 6px;
    max-width: 780px;
    width: 100%;
    overflow: hidden;
    box-shadow: 0 40px 100px rgba(0,0,0,0.8);
    animation: modalIn 0.3s ease;
  }
  @keyframes modalIn { from { opacity:0; transform:scale(0.95); } to { opacity:1; transform:none; } }
  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid rgba(139,94,60,0.2);
  }
  .modal-header h3 { font-family: 'Playfair Display', serif; font-size: 1.2rem; color: var(--parchment); }
  .modal-close {
    background: none;
    border: none;
    color: var(--sepia);
    font-size: 1.5rem;
    cursor: pointer;
    line-height: 1;
    transition: color 0.2s;
  }
  .modal-close:hover { color: var(--rose); }
  .modal-video { width: 100%; display: block; max-height: 450px; background: #000; }
  .modal-meta { padding: 1rem 1.5rem; }
  .modal-meta-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem 1.5rem; margin-bottom: 1rem; }
  .modal-meta-item { font-size: 0.85rem; }
  .modal-meta-label { color: var(--sepia); font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; }
  .modal-note { font-style: italic; color: var(--dust); font-size: 0.95rem; line-height: 1.6; margin-top: 0.5rem; }

  /* Share panel */
  .share-panel {
    background: rgba(139,94,60,0.08);
    border: 1px solid rgba(139,94,60,0.2);
    border-radius: 4px;
    padding: 1rem;
    margin-top: 1rem;
  }
  .share-panel h4 { font-family: 'Playfair Display', serif; font-size: 0.95rem; margin-bottom: 0.7rem; color: var(--amber); }
  .share-code-row { display: flex; gap: 0.5rem; }
  .share-code-input {
    flex: 1;
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(139,94,60,0.3);
    color: var(--parchment);
    padding: 0.5rem 0.8rem;
    border-radius: 3px;
    font-family: 'Crimson Pro', serif;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
  }
  .copy-btn {
    background: rgba(200,135,42,0.15);
    border: 1px solid rgba(200,135,42,0.3);
    color: var(--amber);
    padding: 0.5rem 0.9rem;
    border-radius: 3px;
    cursor: pointer;
    font-size: 0.85rem;
    transition: all 0.2s;
  }
  .copy-btn:hover { background: rgba(200,135,42,0.25); }
  .share-note { font-size: 0.78rem; color: rgba(245,237,224,0.35); font-style: italic; margin-top: 0.5rem; }

  /* Share input */
  .share-email-row { display: flex; gap: 0.5rem; margin-top: 0.7rem; }
  .share-email-input {
    flex: 1;
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(139,94,60,0.3);
    color: var(--parchment);
    padding: 0.5rem 0.8rem;
    border-radius: 3px;
    font-family: 'Crimson Pro', serif;
    font-size: 0.9rem;
  }

  /* ── SHARED ACCESS TAB ── */
  #tab-shared { display: none; }
  #tab-shared.active { display: block; }
  .shared-header h2 { font-family: 'Sacramento', cursive; font-size: 2.8rem; color: var(--blush); margin-bottom: 0.5rem; }
  .shared-header p { color: var(--dust); font-style: italic; font-size: 1rem; margin-bottom: 2rem; }

  .access-form {
